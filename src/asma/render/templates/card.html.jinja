<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
  @font-face {
    font-family: "Playfair Display";
    src: url("file://{{ fonts_dir }}/PlayfairDisplay-Bold.woff2") format("woff2");
    font-weight: 700;
  }
  @font-face {
    font-family: "Playfair Display";
    src: url("file://{{ fonts_dir }}/PlayfairDisplay-Black.woff2") format("woff2");
    font-weight: 900;
  }
  @font-face {
    font-family: "Inter";
    src: url("file://{{ fonts_dir }}/Inter-Regular.woff2") format("woff2");
    font-weight: 400;
  }
  @font-face {
    font-family: "Inter";
    src: url("file://{{ fonts_dir }}/Inter-SemiBold.woff2") format("woff2");
    font-weight: 600;
  }

  :root {
    --bg: {{ theme.bg }};
    --ink: {{ theme.ink }};
    --accent: {{ theme.accent }};
    --rule: {{ theme.rule }};
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    width: {{ width }}px;
    height: {{ height }}px;
    background: var(--bg);
    overflow: hidden;
  }

  body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 88px 84px;
    font-family: "Inter", sans-serif;
    color: var(--ink);
  }

  .kicker {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 30px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
  }

  .rule {
    width: 72px;
    height: 4px;
    background: var(--accent);
    margin-bottom: 36px;
  }

  .headline {
    font-family: "Playfair Display", serif;
    font-weight: 900;
    font-size: {{ headline_size }}px;
    line-height: 1.14;
    letter-spacing: -0.01em;
  }

  .subtext {
    margin-top: 40px;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 34px;
    line-height: 1.45;
    color: var(--ink);
    opacity: 0.82;
  }

  .footer {
    position: absolute;
    left: 84px;
    right: 84px;
    bottom: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dots { display: flex; gap: 10px; }
  .dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--rule);
  }
  .dot.active { background: var(--accent); }

  .handle {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 24px;
    color: var(--ink);
    opacity: 0.55;
    letter-spacing: 0.02em;
  }
</style>
</head>
<body>
  {% if kicker %}<div class="kicker">{{ kicker }}</div>{% endif %}
  <div class="rule"></div>
  <div class="headline">{{ headline }}</div>
  {% if subtext %}<div class="subtext">{{ subtext }}</div>{% endif %}

  {% if total_slides and total_slides > 1 %}
  <div class="footer">
    <div class="dots">
      {% for i in range(total_slides) %}
      <div class="dot{% if i == slide_index %} active{% endif %}"></div>
      {% endfor %}
    </div>
    <div class="handle">{{ handle }}</div>
  </div>
  {% else %}
  <div class="footer">
    <div></div>
    <div class="handle">{{ handle }}</div>
  </div>
  {% endif %}
</body>
</html>
