__pycache__/
*.pyc
.venv/
.env
*.egg-info/
.pytest_cache/
.ruff_cache/
dist/
build/

# Rendered/generated media — reproducible from data/*.jsonl + code, not committed
assets/rendered/
*.mp4
*.png
!assets/audio/README.md

# Piper voice model (~60MB) — downloaded via `python -m piper.download_voices`,
# not committed, same convention as Playwright's browser binaries. A trailing-slash
# directory pattern here would prune the whole tree and silently defeat the README.md
# negation below (git can't re-include a file inside an excluded directory) — the `/*`
# form excludes contents as file globs instead, so the negation actually takes effect.
assets/tts/*
!assets/tts/README.md
