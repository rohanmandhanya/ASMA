# Copy to .env for local dry-run development. Never commit the real .env.
# In production these are GitHub Actions repo secrets, injected as env vars — see .github/workflows/.

# Content generation
ANTHROPIC_API_KEY=

# Text-to-speech (Reels voiceover)
TTS_API_KEY=

# Instagram Graph API
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
FB_APP_ID=
FB_APP_SECRET=

# GitHub secret-writing PAT, used only by refresh-token.yml to rotate IG_ACCESS_TOKEN
GH_PAT_FOR_SECRETS=

# Media hosting (Cloudflare R2 — S3-compatible). Leave unset to use the GitHub Releases fallback.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 100-follower milestone email (see growth/milestone_notifier.py)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
MILESTONE_EMAIL_TO=nate@kiloforge.com

# Safety valve — never touches the network when true. Always default true locally.
DRY_RUN=true
