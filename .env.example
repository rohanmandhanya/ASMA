# Copy to .env for local dry-run development. Never commit the real .env.
# In production these are GitHub Actions repo secrets, injected as env vars — see .github/workflows/.

# Content generation — Gemini (free tier comfortably covers this project's
# entire call volume; no billing/card required)
GEMINI_API_KEY=

# Reel voiceovers use Piper (local, free, offline TTS) — no API key needed.
# See README's "Local setup" for the one-time voice-model download step.

# Reel background illustrations via Pollinations.ai — free, no billing account.
# Fully optional: works with zero setup (anonymous, watermarked); a free
# registered token here just unlocks `nologo` + a faster rate tier. Quiz
# carousels don't use this at all, see render/flow_art.py.
POLLINATIONS_API_TOKEN=

# Instagram Graph API — Instagram Login flow (no Facebook Page needed)
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
IG_APP_ID=
IG_APP_SECRET=

# GitHub secret-writing PAT, used only by refresh-token.yml to rotate IG_ACCESS_TOKEN
GH_PAT_FOR_SECRETS=

# Media hosting (Cloudflare R2 — S3-compatible). Leave unset to use the GitHub Releases fallback.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 100-follower milestone email (see growth/milestone_notifier.py)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
MILESTONE_EMAIL_TO=nate@kiloforge.com

# Safety valve — never touches the network when true. Always default true locally.
DRY_RUN=true
